{
  "name": "skill-spark",
  "version": "0.1.0",
  "description": "Universal skill manager for AI coding agents - merge of Fire-Skill and Flins",
  "type": "module",
  "bin": {
    "skill-spark": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --minify",
    "build:exe": "bun build src/index.ts --compile --outfile dist/skill-spark",
    "build:all": "bun run build && bun run build:exe",
    "dev": "bun src/index.ts",
    "typecheck": "tsgo --noEmit",
    "format": "biome format --write src/",
    "lint": "biome lint src/",
    "check": "biome check src/"
  },
  "keywords": [
    "skills",
    "ai",
    "agents",
    "meta-skill",
    "claude",
    "gemini"
  ],
  "author": "SkillSpark Contributors",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "tar-stream": "^3.2.0",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@biomejs/cli-darwin-x64": "^2.4.16",
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "@types/tar-stream": "^3.1.4",
    "@types/yauzl": "^3.4.0",
    "bun-types": "^1.3.14"
  }
}
