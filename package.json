{
  "name": "skill-spark",
  "version": "0.1.0",
  "description": "Universal skill manager for AI coding agents - merge of Fire-Skill and Flins",
  "type": "module",
  "bin": {
    "skill-spark": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --minify",
    "dev": "bun src/index.ts",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "skills",
    "ai",
    "agents",
    "meta-skill",
    "claude",
    "gemini"
  ],
  "author": "SkillSpark Contributors",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "tar-stream": "^3.2.0",
    "yauzl": "^3.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "@types/tar-stream": "^3.1.4",
    "@types/yauzl": "^2.10.3",
    "bun-types": "^1.3.14"
  }
}