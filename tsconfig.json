{
  "name": "@skill-spark",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@skill-spark/skill-cli": ["./packages/skill-cli/src/index.ts"],
      "@skill-spark/skill-core": ["./packages/skill-core/src/index.ts"],
      "@skill-spark/skill-core/*": ["./packages/skill-core/src/*.ts"],
      "@skill-spark/skill-schemas": ["./packages/skill-schemas/src/index.ts"]
    }
  },
  "include": ["src/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist", "references-projects"]
}
